# DeepSeek API key（必填）
DEEPSEEK_API_KEY=sk-你的key

# 工作目录（可选，默认 ./sandbox/test）
# 改为你项目的绝对路径或相对路径：
# WORKSPACE_DIR=/path/to/your/project

# Agent Gateway 端口映射（可选，默认值如下）
# 如果本地有 Hermes Gateway 在运行，改这里避免端口冲突
# MASTER_PORT=8642
# JUDGE_PORT=8643
# REVIEWER_PORT=8644
# PM_PORT=8645
# DEV_PORT=8646
# QA_PORT=8647
