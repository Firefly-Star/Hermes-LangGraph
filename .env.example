# DeepSeek API key（必填）
DEEPSEEK_API_KEY=sk-你的key

# 终端后端模式：local（容器内）或 ssh（宿主机），默认 local
TERMINAL_ENV=ssh

# SSH 配置（TERMINAL_ENV=ssh 时必填，SSH_HOST 不填则自动检测）
SSH_USER=你的WSL2用户名
# SSH_HOST=host.docker.internal

# Agent Gateway 端口映射（可选，默认值如下）
# 如果本地有 Hermes Gateway 在运行，改这里避免端口冲突
# MASTER_PORT=8642
# JUDGE_PORT=8643
# REVIEWER_PORT=8644
# PM_PORT=8645
# DEV_PORT=8646
# QA_PORT=8647
